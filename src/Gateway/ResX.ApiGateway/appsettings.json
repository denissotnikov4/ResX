{
  "Jwt": {
    "SecretKey": "change-this-super-secret-key-in-production-must-be-at-least-32-chars",
    "Issuer": "ResX.Identity",
    "Audience": "ResX"
  },
  "Cors": {
    "Origins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "listings-route": {
        "ClusterId": "listings-cluster",
        "Match": {
          "Path": "/api/listings/{**catch-all}"
        }
      },
      "categories-route": {
        "ClusterId": "listings-cluster",
        "Match": {
          "Path": "/api/categories/{**catch-all}"
        }
      },
      "transactions-route": {
        "ClusterId": "transactions-cluster",
        "Match": {
          "Path": "/api/transactions/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "messaging-route": {
        "ClusterId": "messaging-cluster",
        "Match": {
          "Path": "/api/conversations/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "messaging-hub-route": {
        "ClusterId": "messaging-cluster",
        "Match": {
          "Path": "/hubs/chat/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "charity-route": {
        "ClusterId": "charity-cluster",
        "Match": {
          "Path": "/api/charity/{**catch-all}"
        }
      },
      "disputes-route": {
        "ClusterId": "disputes-cluster",
        "Match": {
          "Path": "/api/disputes/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "analytics-route": {
        "ClusterId": "analytics-cluster",
        "Match": {
          "Path": "/api/analytics/{**catch-all}"
        }
      },
      "files-route": {
        "ClusterId": "files-cluster",
        "Match": {
          "Path": "/api/files/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://identity-service:8080"
          }
        }
      },
      "users-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://users-service:8080"
          }
        }
      },
      "listings-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://listings-service:8080"
          }
        }
      },
      "transactions-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://transactions-service:8080"
          }
        }
      },
      "messaging-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://messaging-service:8080"
          }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://notifications-service:8080"
          }
        }
      },
      "charity-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://charity-service:8080"
          }
        }
      },
      "disputes-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://disputes-service:8080"
          }
        }
      },
      "analytics-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://analytics-service:8080"
          }
        }
      },
      "files-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://files-service:8080"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*"
}
