# ===========================================================================
# .env.example — template for Timeweb Cloud App Platform deployment.
# Copy to .env (or set as App Platform "Environment Variables"); never commit.
# ===========================================================================

# --- JWT ---------------------------------------------------------------------
JWT_SECRET_KEY=change-this-to-a-strong-secret-min-32-chars
JWT_ISSUER=ResX.Identity
JWT_AUDIENCE=ResX
JWT_ACCESS_EXPIRY_MIN=60
JWT_REFRESH_EXPIRY_DAYS=30

# --- CORS --------------------------------------------------------------------
# Allowed frontend origin for the gateway (single value, no trailing slash).
FRONTEND_ORIGIN=https://app.your-domain.com

# --- PostgreSQL (Timeweb DBaaS) ----------------------------------------------
# One cluster, 9 databases. Create them once via psql or the panel:
#   CREATE DATABASE resx_identity; ... (see scripts/init-databases.sql)
# Then replace <host>/<user>/<password>/<port> below.
IDENTITY_DB_CONNECTION=Host=<pg-host>;Port=5432;Database=resx_identity;Username=<user>;Password=<password>;SslMode=Require;Trust Server Certificate=true
USERS_DB_CONNECTION=Host=<pg-host>;Port=5432;Database=resx_users;Username=<user>;Password=<password>;SslMode=Require;Trust Server Certificate=true
LISTINGS_DB_CONNECTION=Host=<pg-host>;Port=5432;Database=resx_listings;Username=<user>;Password=<password>;SslMode=Require;Trust Server Certificate=true
TRANSACTIONS_DB_CONNECTION=Host=<pg-host>;Port=5432;Database=resx_transactions;Username=<user>;Password=<password>;SslMode=Require;Trust Server Certificate=true
MESSAGING_DB_CONNECTION=Host=<pg-host>;Port=5432;Database=resx_messaging;Username=<user>;Password=<password>;SslMode=Require;Trust Server Certificate=true
NOTIFICATIONS_DB_CONNECTION=Host=<pg-host>;Port=5432;Database=resx_notifications;Username=<user>;Password=<password>;SslMode=Require;Trust Server Certificate=true
CHARITY_DB_CONNECTION=Host=<pg-host>;Port=5432;Database=resx_charity;Username=<user>;Password=<password>;SslMode=Require;Trust Server Certificate=true
DISPUTES_DB_CONNECTION=Host=<pg-host>;Port=5432;Database=resx_disputes;Username=<user>;Password=<password>;SslMode=Require;Trust Server Certificate=true
FILES_DB_CONNECTION=Host=<pg-host>;Port=5432;Database=resx_files;Username=<user>;Password=<password>;SslMode=Require;Trust Server Certificate=true

# --- Redis (Timeweb DBaaS or VPS) --------------------------------------------
# Format: <host>:<port>,password=<password>,ssl=true
REDIS_CONNECTION=<redis-host>:6379,password=<redis-password>,ssl=true

# --- RabbitMQ (VPS — Timeweb doesn't have managed RabbitMQ at the moment) ----
RABBIT_HOST=<rabbit-host>
RABBIT_PORT=5672
RABBIT_VHOST=resx
RABBIT_USER=<rabbit-user>
RABBIT_PASSWORD=<rabbit-password>

# --- Timeweb Object Storage (S3-compatible, MinIO replacement) ---------------
# Get these from Cloud panel → "Объекты (S3)" → bucket → credentials widget.
S3_SERVICE_URL=https://s3.twcstorage.ru
# Browser-facing URL for presigned downloads. Either same as ServiceUrl,
# or your bucket-bound subdomain (e.g. https://files.your-domain.com).
S3_PUBLIC_URL=https://s3.twcstorage.ru
S3_ACCESS_KEY=<s3-access-key>
S3_SECRET_KEY=<s3-secret-key>
S3_BUCKET_NAME=resx-files
S3_REGION=ru-1
